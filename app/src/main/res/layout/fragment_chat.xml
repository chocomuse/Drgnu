<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_neumorphic_box"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pretendard_bold"
            android:text="Dr.GUN AI Analysis System"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="김도윤 / 조재민 / 김우성 / 안재영"
            android:textColor="#B0B0B0"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_analysis_box"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_neumorphic_box"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/btn_chat_record"
        app:layout_constraintTop_toBottomOf="@id/layout_header">

        <LinearLayout
            android:id="@+id/layout_pills_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_neumorphic_title"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="14dp">

            <TextView
                android:id="@+id/pill_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_neumorphic_pill"
                android:backgroundTint="@color/neon_blue"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:text="실시간 분석"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="@font/pretendard_bold" />

            <TextView
                android:id="@+id/pill_wait"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_neumorphic_pill"
                android:backgroundTint="@color/white"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:text="대기 중"
                android:textColor="@color/white"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/pill_ready"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_neumorphic_pill"
                android:backgroundTint="@color/white"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:text="준비완료"
                android:textColor="@color/white"
                android:textSize="11sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/layout_empty_popup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="32dp"
                android:background="@drawable/bg_neumorphic_box"
                android:backgroundTint="#2D3748"
                android:elevation="12dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_neumorphic_pill"
                    android:backgroundTint="@color/neon_green"
                    android:fontFamily="@font/pretendard_bold"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="7dp"
                    android:text="분석 준비완료"
                    android:textColor="@color/main_bg"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingExtra="8dp"
                    android:text="아직 대화기록이 없습니다.\n\n녹음을 시작하면 답변과 위험도 분석이\n이곳에 차례대로 표시됩니다."
                    android:textColor="#D0D0D0"
                    android:textSize="14sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_chat"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="16dp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btn_chat_record"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_glass"
        android:backgroundTint="@color/neon_blue"
        android:elevation="8dp"
        android:fontFamily="@font/pretendard_bold"
        android:stateListAnimator="@null"
        android:text="녹음 시작"
        android:textColor="@color/white"
        android:textSize="19sp"
        app:cornerRadius="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteX="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>