<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1B23">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_custom_nav"
        android:elevation="10dp"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout android:id="@+id/btn_nav_dashboard" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <View android:id="@+id/nav_dashboard_pill" android:layout_width="60dp" android:layout_height="50dp" android:layout_gravity="center" android:background="@drawable/bg_selected_pill" android:visibility="invisible" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#FFFFFF" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="대시보드" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout android:id="@+id/btn_nav_chat" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <View android:id="@+id/nav_chat_pill" android:layout_width="60dp" android:layout_height="50dp" android:layout_gravity="center" android:background="@drawable/bg_selected_pill" android:visibility="invisible" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_send" app:tint="#FFFFFF" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="대화" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout android:id="@+id/btn_nav_analysis" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <View android:id="@+id/nav_analysis_pill" android:layout_width="60dp" android:layout_height="50dp" android:layout_gravity="center" android:background="@drawable/bg_selected_pill" android:visibility="invisible" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_manage" app:tint="#FFFFFF" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="분석" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout android:id="@+id/btn_nav_manage" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <View android:id="@+id/nav_manage_pill" android:layout_width="60dp" android:layout_height="50dp" android:layout_gravity="center" android:background="@drawable/bg_selected_pill" android:visibility="invisible" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_info_details" app:tint="#FFFFFF" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="관리" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>