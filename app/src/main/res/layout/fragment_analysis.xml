<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0B10">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_analysis"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="110dp">

        <LinearLayout
            android:id="@+id/layout_analysis_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dash_card_dark"
                android:orientation="vertical"
                android:padding="20dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—  세션 요약" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" />
                    <TextView android:layout_width="24dp" android:layout_height="24dp" android:layout_toStartOf="@id/tv_wait_badge" android:layout_marginEnd="8dp" android:background="@drawable/bg_circle_dark" android:gravity="center" android:text="?" android:textColor="#8A8A8E" android:textSize="12sp" />
                    <TextView android:id="@+id/tv_wait_badge" android:layout_width="wrap_content" android:layout_height="24dp" android:layout_alignParentEnd="true" android:background="@drawable/bg_dash_toggle_pill" android:gravity="center" android:paddingHorizontal="12dp" android:text="대기" android:textColor="#8A8A8E" android:textSize="11sp" />
                </RelativeLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:background="@drawable/bg_dash_toggle_pill" android:orientation="vertical" android:padding="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="최신 반영 점수" android:textColor="#8A8A8E" android:textSize="11sp" /><TextView android:id="@+id/tv_session_score" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="—" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="아직 분석된 대화가 없습니다." android:textColor="#8A8A8E" android:textSize="12sp" /></LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_dash_toggle_pill" android:orientation="vertical" android:padding="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="위험도" android:textColor="#8A8A8E" android:textSize="11sp" /><TextView android:id="@+id/tv_session_risk" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="분석 전" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" /></LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_dash_toggle_pill" android:orientation="vertical" android:padding="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="추세" android:textColor="#8A8A8E" android:textSize="11sp" /><TextView android:id="@+id/tv_session_trend" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="—" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" /></LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_dash_toggle_pill" android:orientation="vertical" android:padding="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="모드" android:textColor="#8A8A8E" android:textSize="11sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="로컬 모델" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" /></LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_dash_card_dark"
                android:orientation="vertical"
                android:padding="20dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—  AI 분석 결과" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" /><TextView android:layout_width="24dp" android:layout_height="24dp" android:layout_toStartOf="@id/tv_ai_badge" android:layout_marginEnd="8dp" android:background="@drawable/bg_circle_dark" android:gravity="center" android:text="?" android:textColor="#8A8A8E" android:textSize="12sp" /><TextView android:id="@+id/tv_ai_badge" android:layout_width="wrap_content" android:layout_height="24dp" android:layout_alignParentEnd="true" android:background="@drawable/bg_dash_toggle_pill" android:gravity="center" android:paddingHorizontal="12dp" android:text="대기" android:textColor="#8A8A8E" android:textSize="11sp" /></RelativeLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="아직 분석 전입니다. 대화를 시작하면 판단, 점수, 근거가 아래에 표시됩니다." android:textColor="#8A8A8E" android:textSize="12sp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="24dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="판단" android:textColor="#FFFFFF" android:textSize="13sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="대기" android:textColor="#FFFFFF" android:textStyle="bold" /></LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2C3A" android:layout_marginVertical="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="의심 점수" android:textColor="#FFFFFF" android:textSize="13sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#FFFFFF" android:textStyle="bold" /></LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2C3A" android:layout_marginVertical="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="위험도" android:textColor="#FFFFFF" android:textSize="13sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="분석 전" android:textColor="#FFFFFF" android:textStyle="bold" /></LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2C3A" android:layout_marginVertical="12dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="근거" android:textColor="#8A8A8E" android:textSize="13sp" />
                <TextView android:id="@+id/tv_ai_reason_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_dash_toggle_pill" android:padding="16dp" android:text="아직 분석 결과가 없습니다. 녹음을 시작하면 판단, 점수, 근거가 이곳에 표시됩니다." android:textColor="#A1A1AA" android:textSize="13sp" android:lineSpacingExtra="5dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:background="@drawable/bg_dash_card_dark" android:orientation="vertical">
                <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/layout_toggle_lang" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp"><ImageView android:id="@+id/iv_icon_lang" android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_sort_by_size" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical" app:layout_constraintStart_toEndOf="@id/iv_icon_lang" app:layout_constraintEnd_toStartOf="@id/iv_arrow_lang" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="세부 분석" android:textColor="#8A8A8E" android:textSize="11sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="언어 특징 / 신뢰도 펼치기" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" /></LinearLayout><ImageView android:id="@+id/iv_arrow_lang" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/arrow_down_float" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:tint="#2DB4FF" /></androidx.constraintlayout.widget.ConstraintLayout>
                <LinearLayout android:id="@+id/layout_detail_lang" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingBottom="20dp" android:visibility="gone">
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2C3A" android:layout_marginBottom="20dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_dash_toggle_pill" android:orientation="vertical" android:padding="20dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—  언어 특징 점수 분해" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" /><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="16dp"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="질문 반복" android:textColor="#FFFFFF" android:textSize="12sp" /><TextView android:id="@+id/tv_score_repeat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textStyle="bold" /></LinearLayout><ProgressBar android:id="@+id/pb_score_repeat" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="8dp" android:layout_marginTop="8dp" android:progress="0" android:progressTint="#2DB4FF" android:progressBackgroundTint="#1E202B"/></LinearLayout><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="16dp"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="기억 혼란" android:textColor="#FFFFFF" android:textSize="12sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textStyle="bold" /></LinearLayout><ProgressBar style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="8dp" android:layout_marginTop="8dp" android:progress="0" android:progressTint="#2DB4FF" android:progressBackgroundTint="#1E202B"/></LinearLayout></LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_dash_toggle_pill" android:orientation="vertical" android:padding="20dp"><RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—  분석 신뢰도" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" /><TextView android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:background="@drawable/bg_circle_dark" android:gravity="center" android:text="?" android:textColor="#8A8A8E" android:textSize="12sp" /></RelativeLayout><TextView android:id="@+id/tv_confidence_score" android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginTop="16dp" android:background="@drawable/bg_dash_card_dark" android:gravity="center" android:text="—\n분석 신뢰도" android:textColor="#FFFFFF" android:textSize="14sp" /></LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_dash_toggle_pill" android:orientation="vertical" android:padding="20dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—  언어 특징 레이더" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" /><com.github.mikephil.charting.charts.RadarChart android:id="@+id/radar_chart" android:layout_width="match_parent" android:layout_height="250dp" android:layout_marginTop="16dp" /></LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_dash_card_dark" android:orientation="vertical" android:layout_marginTop="16dp"><androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/layout_toggle_history" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp"><ImageView android:id="@+id/iv_icon_history" android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_recent_history" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical" app:layout_constraintStart_toEndOf="@id/iv_icon_history" app:layout_constraintEnd_toStartOf="@id/iv_arrow_history" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="과거 기록" android:textColor="#8A8A8E" android:textSize="11sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="턴 타임라인 / 리포트 펼치기" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" /></LinearLayout><ImageView android:id="@+id/iv_arrow_history" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/arrow_down_float" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:tint="#2DB4FF" /></androidx.constraintlayout.widget.ConstraintLayout><LinearLayout android:id="@+id/layout_detail_history" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingBottom="20dp" android:visibility="gone"><View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2C3A" android:layout_marginBottom="20dp"/><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_dash_toggle_pill" android:orientation="vertical" android:padding="20dp"><RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—  턴 타임라인" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" /><TextView android:layout_width="24dp" android:layout_height="24dp" android:layout_toStartOf="@id/tv_timeline_badge" android:layout_marginEnd="8dp" android:background="@drawable/bg_circle_dark" android:gravity="center" android:text="?" android:textColor="#8A8A8E" android:textSize="12sp" /><TextView android:id="@+id/tv_timeline_badge" android:layout_width="wrap_content" android:layout_height="24dp" android:layout_alignParentEnd="true" android:text="기록 없음" android:textColor="#8A8A8E" android:textSize="11sp" android:gravity="center"/></RelativeLayout><TextView android:layout_width="match_parent" android:layout_height="200dp" android:layout_marginTop="16dp" android:background="@drawable/bg_dash_card_dark" android:gravity="center" android:text="반영된 점수가 누적되면 이곳에 최근 흐름이 표시됩니다." android:textColor="#8A8A8E" android:textSize="13sp" /></LinearLayout></LinearLayout></LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_dash_card_dark" android:orientation="vertical" android:layout_marginTop="16dp"><androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/layout_toggle_memory" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp"><ImageView android:id="@+id/iv_icon_memory" android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_agenda" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" /><LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:orientation="vertical" app:layout_constraintStart_toEndOf="@id/iv_icon_memory" app:layout_constraintEnd_toStartOf="@id/iv_arrow_memory" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="회상 검사" android:textColor="#8A8A8E" android:textSize="11sp" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="기억 회상 테스트 펼치기" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" /></LinearLayout><ImageView android:id="@+id/iv_arrow_memory" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/arrow_down_float" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:tint="#2DB4FF" /></androidx.constraintlayout.widget.ConstraintLayout><LinearLayout android:id="@+id/layout_detail_memory" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingBottom="20dp" android:visibility="gone"><View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2C3A" android:layout_marginBottom="20dp"/><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_dash_toggle_pill" android:orientation="vertical" android:padding="20dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—  기억 회상 테스트" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" /><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="상태" android:textColor="#FFFFFF" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="대기" android:textColor="#FFFFFF" android:textStyle="bold" /></LinearLayout><TextView android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginTop="16dp" android:background="@drawable/bg_dash_card_dark" android:gravity="center" android:text="아직 진행 중인 기억 테스트가 없습니다." android:textColor="#8A8A8E" android:textSize="13sp" /></LinearLayout></LinearLayout></LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <View
        android:id="@+id/view_status_protection"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_status_bar_protection"
        android:alpha="0.8" />

</FrameLayout>